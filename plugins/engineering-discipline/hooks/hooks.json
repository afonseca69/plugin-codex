{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/read_docs_first.sh\"",
            "statusMessage": "Checking docs-first guidance"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/verify_before_commit.sh\"",
            "statusMessage": "Checking commit verification reminder"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/hooks/restart_reminder.sh\"",
            "statusMessage": "Checking runtime restart reminder"
          }
        ]
      }
    ]
  }
}
